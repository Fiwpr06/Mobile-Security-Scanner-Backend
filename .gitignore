# =============================================
# .gitignore for Mobile Security Scanner Backend
# =============================================

# Environment variables - NEVER commit!
.env
*.env
!.env.example

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
.vscode/
*.DS_Store
*.swp
*.swo

# Logs
logs/
*.log

# SSL certificates (generate locally)
nginx/ssl/
!nginx/ssl/.gitkeep

# Docker override files (local customizations)
docker-compose.override.yml

# JVM
hs_err_pid*

# Kotlin
*.class

# Test reports
test-results/
bin/test-results/
out/test-results/
