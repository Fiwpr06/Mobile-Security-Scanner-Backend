# =============================================
# .env.example - Environment Variables Template
# Copy this to .env and fill in real values
# NEVER commit .env to version control!
# =============================================

# -----------------------------------------------
# Application
# -----------------------------------------------
APP_PORT=8080
APP_ENV=production

# -----------------------------------------------
# Database
# -----------------------------------------------
DB_NAME=security_scanner
DB_USERNAME=scanner_user
DB_PASSWORD=change_this_strong_password_here

# -----------------------------------------------
# Redis
# -----------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# -----------------------------------------------
# JWT (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -base64 64
# -----------------------------------------------
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_SECRET_AT_LEAST_256_BITS_LONG_abcdef123456
JWT_ACCESS_EXPIRATION=86400000

# -----------------------------------------------
# Third-Party API Keys (REQUIRED for real scanning)
# -----------------------------------------------
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key
GOOGLE_SAFE_BROWSING_ENABLED=true

VIRUS_TOTAL_API_KEY=your-virustotal-api-key
VIRUS_TOTAL_ENABLED=true

ABUSE_IPDB_API_KEY=your-abuseipdb-api-key
ABUSE_IPDB_ENABLED=true

# -----------------------------------------------
# Scan Engine Weights (must sum to 1.0)
# -----------------------------------------------
SCAN_WEIGHT_GOOGLE=0.5
SCAN_WEIGHT_VIRUSTOTAL=0.3
SCAN_WEIGHT_ABUSEIPDB=0.2

# Risk thresholds
SCAN_THRESHOLD_SAFE=30
SCAN_THRESHOLD_SUSPICIOUS=60

# -----------------------------------------------
# Rate Limiting
# -----------------------------------------------
RATE_LIMIT_DEVICE_REQUESTS=100
RATE_LIMIT_DEVICE_DURATION=60
RATE_LIMIT_IP_REQUESTS=200
RATE_LIMIT_IP_DURATION=60

# -----------------------------------------------
# CORS
# -----------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------
# App Config
# -----------------------------------------------
APP_MINIMUM_APP_VERSION=1.0.0
APP_MAINTENANCE=false
APP_MAINTENANCE_MESSAGE=

# -----------------------------------------------
# Grafana
# -----------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_grafana_password
